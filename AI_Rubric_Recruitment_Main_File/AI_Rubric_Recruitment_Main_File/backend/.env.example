# ── Server ─────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
RELOAD=false
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000
PUBLIC_APP_URL=http://localhost:3000
# Comma-separated extra CORS origins (e.g. https://your-app.vercel.app)
CORS_ORIGINS=

# ── AI (Gemini) ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Auth (recruitment portal) ──────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret

# ── PostgreSQL (screening / rubric + recruitment auth on Railway) ─
DB_HOST=your-postgres-host
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
# Optional override for recruitment SQLAlchemy (defaults to DB_* above on Railway)
RECRUITMENT_DATABASE_URL=

# ── Screening performance ──────────────────────────────────────
EXTRACT_WORKERS=12
STREAM_BATCH_SIZE=15

# ── LinkedIn OAuth ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/platforms/linkedin/oauth/callback
LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social
OAUTH_STATE_TTL=3600
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_API_VERSION=202503

# ── Indeed / ZipRecruiter / Dice (optional) ──────────────────
INDEED_CLIENT_ID=
INDEED_CLIENT_SECRET=
INDEED_EMPLOYER_ID=
ZIPRECRUITER_API_KEY=
DICE_BATCH_USERNAME=
DICE_BATCH_PASSWORD=
DICE_GROUP_ID=

# ── Google OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── SMTP (RTR emails + Dice batch) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_FROM=your-email@company.com
SMTP_USER=your-email@company.com
SMTP_USERNAME=your-email@company.com
SMTP_PASSWORD=your_smtp_app_password
SENDER_EMAIL=your-email@company.com
